LOG_LEVEL=
USERS_FILE=

# Notifications: set APPRISE_URL to an Apprise URL (https://github.com/caronc/apprise) to get
# a per-user metrics notification after each run. NOTIFY_SKIPPED also includes offers that were
# already clipped (skipped) in the notification body; off by default since it's usually the
# noisiest/least useful category.
# APPRISE_URL=
# NOTIFY_SKIPPED=

# Advanced: these are shared across all Albertsons-family banner sites (jewelosco, safeway,
# vons, albertsons, ...) and default to known-good values. Only set these if a banner turns
# out to need its own.
# OCP_APIM_SUB_KEY=
# SWY_API_KEY=
# OKTA_AUTH_SERVER=
# OKTA_CLIENT_ID=
# IBM_CLIENT_ID=
# IBM_CLIENT_SECRET=
